# ============================================================
# TripEase 环境变量配置
#
# 使用方法：
# 1. 复制此文件：cp .env.example .env
# 2. 修改下面的值（尤其是密码和密钥！）
# 3. .env 文件不要提交到 Git（已在 .gitignore 中）
# ============================================================

# MySQL 数据库密码（一定要改成复杂密码！）
DB_PASSWORD=tripease123

# 数据库名
DB_NAME=tripease

# JWT 密钥（用于加密登录令牌，一定要改！）
# 可以用这个命令生成随机密钥：openssl rand -hex 32
JWT_SECRET=please_change_this_secret
